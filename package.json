{
  "name": "MCP-PTB",
  "version": "0.1.0",
  "description": "MCP server for Cisco Packet Tracer zero-config automation via PTBuilder bridge",
  "author": "loonbac21 <joshuarosalesmoreno@hotmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
